<hardvol>
  <ctl name="Tweeters Master Playback Volume" path="speaker">
    <!-- scale matches with SPEAKER_VOLUME_CURVE_DEFAULT only without offset -->
    <per2db>  1, -5375</per2db>
    <per2db> 20, -3700</per2db>
    <per2db> 60, -1575</per2db>
    <per2db>100,     0</per2db>

    <!-- for SY6045 -->
    <db2val>-12600,   3</db2val>
    <db2val>     0, 255</db2val>
  </ctl>

  <ctl name="Woofer Master Playback Volume" path="speaker">
    <!-- scale matches with SPEAKER_VOLUME_CURVE_DEFAULT only without offset -->
    <per2db>  1, -5375</per2db>
    <per2db> 20, -3700</per2db>
    <per2db> 60, -1575</per2db>
    <per2db>100,     0</per2db>

    <!-- for SY6045 -->
    <db2val>-12600,   3</db2val>
    <db2val>     0, 255</db2val>
  </ctl>

  <ctl name="Headphone DAC Playback Volume" path="headphone">
    <!-- scale matches with HEADSET_VOLUME_CURVE_DEFAULT
         but offset is selected from mixer_paths "Headphone DAC Playback Volume"
         except the lowest point -->
    <!-- if you change it, dont forget to change scale in mixer_paths -->
    <per2db>  1, -4800</per2db>
    <per2db> 33, -2900</per2db>
    <per2db> 66, -1425</per2db>
    <per2db>100,  100</per2db>

    <!-- for ES8156 -->
    <db2val>-9550,   0</db2val>
    <db2val> 3200, 255</db2val>
  </ctl>

  <mute name="Tweeters Master Playback Switch" path="speaker" out_on="1" out_off="0" />
  <mute name="Woofer Master Playback Switch" path="speaker" out_on="1" out_off="0" />
  <mute name="Headphone Headphone Switch" path="headphone" out_on="1" out_off="0" />
</hardvol>
